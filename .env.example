# Google Gemini API Key
GOOGLE_API_KEY=your_google_api_key_here

# Supabase Remote Configuration (Get these from your project settings at supabase.com)
SUPABASE_URL=https://<your-project-id>.supabase.co
SUPABASE_KEY=<your_supabase_service_role_key_here>
POSTGRES_PASSWORD=<your_db_password>
SUPABASE_DB_URL=postgresql://postgres.<your-project-id>:<your_db_password>@aws-0-region.pooler.supabase.com:6543/postgres

# Chainlit Configuration
CHAINLIT_PORT=8000
